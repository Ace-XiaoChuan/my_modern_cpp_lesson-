# 更规范的 .gitignore
# 适用于 C++ / CMake / ROS2 (ament/colcon) 项目

## 构建产物（顶层与子目录）
/build/
/install/
/log/
**/build/
**/install/
**/log/

## CMake 相关
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
cmake_uninstall.cmake
compile_commands.json

## 编译生成的二进制/库/中间文件
*.o
*.obj
*.so
*.dylib
*.dll
*.a
*.lib
*.exe
*.out
*.elf
*.app
*.dSYM/

## 常见包/发布目录（Python/其他）
dist/
build/
*.egg-info/
pip-wheel-metadata/

## Python 缓存 / 虚拟环境
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
.venv/
env/
envs/

## ROS / Colcon / Ament
.ament_index/
colcon_ignore

## 编辑器 & IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

## 临时文件 / 编辑器残留
*~
*.swp
*.swo
.DS_Store
Thumbs.db

## 日志 / 临时 / 缓存
*.log
tmp/
temp/
*.tmp

## Conda / local SDK（如果在仓库中出现）
miniconda3/
anaconda3/

## 明确保留（防止误删重要源码/配置文件）
!/.gitignore
!/README*
!/LICENSE*
!/CMakeLists.txt
!/Makefile
!/Dockerfile
!*.cpp
!*.c
!*.h
!*.hpp
!*.md

# 如果你仍希望忽略某些无后缀可执行文件，请按需添加：
# *.run