# -----------------------------------------------------------------------------
# ✨ 最核心的魔法规则
# 99%的C++ gitignore都会漏掉这个
# 自动忽略所有没有后缀的可执行文件，永远不会碰源文件
# -----------------------------------------------------------------------------
*
!*/
!*.*

# -----------------------------------------------------------------------------
# 编译产物
# -----------------------------------------------------------------------------
*.out
*.exe
*.o
*.obj
*.elf
*.a
*.lib
*.so
*.dll
*.dylib
*.dSYM

# -----------------------------------------------------------------------------
# 构建系统
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
build/
_build/
dist/
meson-out/
compile_commands.json

# -----------------------------------------------------------------------------
# 临时和调试文件
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.gdb_history
.valgrindrc
*.pdb
*.idb

# -----------------------------------------------------------------------------
# IDE 和操作系统垃圾
# -----------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# 明确保留我们需要的文件
# -----------------------------------------------------------------------------
!*.gitignore
!*.md
!*.cpp
!*.h
!*.hpp
!*.c
!*.mmd
!LICENSE
!README