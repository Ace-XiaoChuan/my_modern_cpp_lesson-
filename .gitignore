# -----------------------------------------------------------------------------
# ✨ 最核心的魔法规则
# 99%的C++ gitignore都会漏掉这个
# 自动忽略所有没有后缀的可执行文件，永远不会碰源文件
# -----------------------------------------------------------------------------
*
!*/
!*.*
install/
log/
/build/
__pycache__/
*.pyc
*.pyo
*.pyd

# Ament/Colcon 的索引标记（防止提交这些隐藏文件）
.ament_index/
colcon_ignore

# ==========================================
# ✨ 核心规则微调
# ==========================================
# 刚才的规则会漏掉 Dockerfile, Makefile 等没有后缀的源文件
# 建议手动显式保留这些：
!Dockerfile
!Makefile
!CMakeLists.txt

# ==========================================
# ✨ 针对你当前项目的特定修补
# ==========================================
# 刚才你 commit 里出现的 lesson5_composition/install/ 
# 说明你可能在子目录下也运行过 colcon。
# 使用双星号确保所有层级的这些文件夹都被忽略：
**/install/
**/log/
**/build/
# -----------------------------------------------------------------------------
# 编译产物
# -----------------------------------------------------------------------------
*.out
*.exe
*.o
*.obj
*.elf
*.a
*.lib
*.so
*.dll
*.dylib
*.dSYM

# -----------------------------------------------------------------------------
# 构建系统
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
build/
_build/
dist/
meson-out/
compile_commands.json

# -----------------------------------------------------------------------------
# 临时和调试文件
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.gdb_history
.valgrindrc
*.pdb
*.idb

# -----------------------------------------------------------------------------
# IDE 和操作系统垃圾
# -----------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# 明确保留我们需要的文件
# -----------------------------------------------------------------------------
!*.gitignore
!*.md
!*.cpp
!*.h
!*.hpp
!*.c
!*.mmd
!LICENSE
!README